```gitignore
# =====================================
# Dependencies
# =====================================
frontend/node_modules/
backend/node_modules/

# =====================================
# Environment Variables
# =====================================
frontend/.env
frontend/.env.*
!frontend/.env.example

backend/.env
backend/.env.*
!backend/.env.example

# =====================================
# Logs
# =====================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =====================================
# Runtime files
# =====================================
pids/
*.pid
*.seed
*.pid.lock

# =====================================
# Build / Distribution
# =====================================
frontend/dist/
frontend/build/

backend/dist/
backend/build/

coverage/
.nyc_output/

# =====================================
# Cache files
# =====================================
.cache/
.parcel-cache/
.vite/
.eslintcache
.stylelintcache
.npm/
.pnpm-store/

# =====================================
# Vite
# =====================================
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# =====================================
# TypeScript (safe to keep even if unused)
# =====================================
*.tsbuildinfo

# =====================================
# IDE / Editor
# =====================================
.vscode/
!.vscode/extensions.json

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# =====================================
# OS files
# =====================================
.DS_Store
Thumbs.db

# =====================================
# Package managers
# =====================================
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# =====================================
# Misc
# =====================================
node_modules/
jspm_packages/
*.tgz
.node_repl_history
```
